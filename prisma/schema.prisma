generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}

model User {
  id       String   @id @default(uuid())
  username String   @unique
  password String
  folders  Folder[]
  files    File[]
}

model Folder {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  files     File[] 
  
  // 👇 Made these optional so folders can be private by default
  sharedId  String?  
  expiresAt DateTime?
  //sel referential relation 
  parentId String?   //IF NULL this folder lives in the Root directory!
  parent    Folder? @relation("FolderToFolder",fields:[parentId],references: [id],onDelete: Cascade)
  children Folder[] @relation("FolderToFolder")
}

model File {
  id         String   @id @default(uuid())
  name       String 
  path       String
  size       String   // (Tip: Int is sometimes easier here if storing bytes, but String works!)
  uploadTime DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  folder     Folder?  @relation(fields: [folderId], references: [id])
  folderId   String?
}