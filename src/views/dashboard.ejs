<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Drive</title>
</head>
<body>
    <main>
        <h1>Welcome to your Drive, <%= user.username %>!</h1>
        <form action="/logout" method="POST">
            <button type="submit">Logout</button>
        </form>
        <hr>

        <h3>Create New Folder</h3>
        <form action="/folders" method="POST">
            <input type="text" name="name" placeholder="Folder Name" required>
            <button type="submit">Create</button>
        </form>
        <hr>
        <h3>Upload File</h3>
        <form action="/files" method="POST" enctype="multipart/form-data">
            <input type="file" name="file" required>
            <button type="submit">Upload</button>
        </form>

        <hr>

        <h2>My Folders</h2>
        <ul>
            <% if (contents.folders.length === 0) { %>
                <li>No folders yet.</li>
            <% } else { %>
                <% contents.folders.forEach(folder => { %>
                    <li>📁 <a href="/folders/<%= folder.id %>"><%= folder.name %></a>
                    <form action="/folders/<%= folder.id %>/delete" method="POST" style="margin: 0;">
                        <button type="submit" style="color: red; background: none; border: 1px solid red; cursor: pointer;">Delete</button>
                    </form>
                    </li>
                <% }) %>
            <% } %>
        </ul>

        <h2>My Files</h2>
        <ul>
            <% if (contents.files.length === 0) { %>
                <li>No files here.</li>
            <% } else { %>
                <% contents.files.forEach(file => { %>
                    <li style="margin-bottom: 10px;">
                        📄 <%= file.name %> 
                        <span style="color: gray; font-size: 0.8em;">(<%= file.size %> bytes)</span>
                        
                        <a href="/files/<%= file.id %>/download" style="margin-left: 10px;">⬇️ Download</a>
                        <form action="/files/<%= file.id %>/delete" method="POST" style="margin: 0;">
                            <button type="submit" style="color: red; background: none; border: 1px solid red; cursor: pointer;">Delete</button>
                        </form>
                    </li>
                <% }) %>
            <% } %>
        </ul>
    </main>
</body>
</html>