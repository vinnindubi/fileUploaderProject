<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= currentFolder.name %></title>
</head>
<body>
    <main>
        <% if (currentFolder.parentId) { %>
            <a href="/folders/<%= currentFolder.parentId %>">⬅ Back to <%= currentFolder.parent.name %></a>
        <% } else { %>
            <a href="/dashboard">⬅ Back to My Drive</a>
        <% } %>

        <h1>📁 <%= currentFolder.name %></h1>
        <hr>

        <h3>Create Subfolder</h3>
        <form action="/folders" method="POST">
            <input type="text" name="name" placeholder="Folder Name" required>
            <input type="hidden" name="parentId" value="<%= currentFolder.id %>">
            <button type="submit">Create Subfolder</button>
        </form>
        <hr>
        <h3>Upload File</h3>
        <form action="/files" method="POST" enctype="multipart/form-data">
            <input type="file" name="file" required>
            
            <input type="hidden" name="folderId" value="<%= currentFolder.id %>">
            
            <button type="submit">Upload</button>
        </form>
        <hr>

        <h2>Folders in <%= currentFolder.name %></h2>
        <ul>
            <% if (currentFolder.children.length === 0) { %>
                <li>This folder is empty.</li>
            <% } else { %>
                <% currentFolder.children.forEach(childFolder => { %>
                    <li style="margin-bottom: 15px;">
                        📁 <a href="/folders/<%= childFolder.id %>"><%= childFolder.name %></a>
                        
                        <!-- Fixed to use childFolder.id -->
                        <form action="/folders/<%= childFolder.id %>/delete" method="POST" style="display: inline-block; margin: 0 10px;">
                            <button type="submit" style="color: red; background: none; border: 1px solid red; cursor: pointer;">Delete</button>
                        </form>
                        
                        <!-- Fixed to use childFolder.id -->
                        <form onsubmit="shareFolder(event, '<%= childFolder.id %>')" class="share-form" style="display: inline-flex; gap: 10px;">
                            <select id="duration-<%= childFolder.id %>" class="form-select" required>
                                <option value="1">1 Day</option>
                                <option value="7">7 Days</option>
                                <option value="10">10 Days</option>
                                <option value="30">30 Days</option>
                            </select>
                            <button type="submit" class="btn btn-primary">🔗 Create Share Link</button>
                        </form>
                    </li>
                <% }) %>
            <% } %>
        </ul>
        
        <h2>Files in <%= currentFolder.name %></h2>
        <ul>
            <% if (currentFolder.files.length === 0) { %>
                <li>No files here.</li>
            <% } else { %>
                <% currentFolder.files.forEach(file => { %>
                    <li style="margin-bottom: 10px;">
                        📄 <%= file.name %> 
                        <span style="color: gray; font-size: 0.8em;">(<%= file.size %> bytes)</span>
                        
                        <a href="/files/download/<%= file.id %>" class="btn btn-primary" style="margin-left: 10px;">⬇️ Download</a>
                        <button onclick="copyToClipboard('<%= file.id %>')" class="btn btn-secondary" style="margin-left: 10px;">
                            🔗 Copy Share Link
                        </button>
                        <form action="/files/<%= file.id %>/delete" method="POST" style="margin: 0;">
                            <button type="submit" style="color: red; background: none; border: 1px solid red; cursor: pointer;">Delete</button>
                        </form>
                    </li>
                <% }) %>
            <% } %>
        </ul>
    </main>
    <script>
    async function shareFolder(event, folderId) {
        event.preventDefault(); // Stop page reload
        
        const durationDays = document.getElementById(`duration-${folderId}`).value;

        try {
            // Send the folderId and duration to your backend
            const response = await fetch(`/share/folder/${folderId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ duration: durationDays })
            });
            
            const data = await response.json();
            
            // Build the URL using the returned sharedId
            const shareUrl = `${window.location.origin}/share/folder-view/${data.sharedId}`;
            
            await navigator.clipboard.writeText(shareUrl);
            alert(`Link copied! It will expire in ${durationDays} days.\n\n${shareUrl}`);
        } catch (err) {
            console.error(err);
            alert("Failed to generate link.");
        }
    }
    async function copyToClipboard(fileId) {
        // Notice we use /share/ here instead of /share/folder-view/
        const shareUrl = `${window.location.origin}/share/${fileId}`;
        try {
            await navigator.clipboard.writeText(shareUrl);
            alert(`File link copied!\n\n${shareUrl}`);
        } catch (err) {
            console.error("Failed to copy", err);
            alert("Failed to copy link.");
        }
    }
</script>
</body>
</html>